# Raw data — never commit source data files
data/raw/

# Processed outputs — generated by the pipeline, not source code
data/processed/

# DuckDB database file — this is a binary file, not source code
*.duckdb

# Virtual environment — never commit this, it is machine-specific
venv/

# Python cache files — generated automatically, not source code
__pycache__/
*.pyc
*.pyo

# VS Code settings — machine-specific, not project code
.vscode/

# Kaggle credentials — NEVER commit this under any circumstances
.kaggle/
kaggle.json

# OS-generated files
.DS_Store
Thumbs.db

# dbt build artifacts — generated when dbt run executes, not source code
ecommerce_dbt/target/
ecommerce_dbt/dbt_packages/

# dbt scaffold folders — empty, generated by dbt init, not source code
ecommerce_dbt/analyses/
ecommerce_dbt/macros/
ecommerce_dbt/seeds/
ecommerce_dbt/snapshots/
ecommerce_dbt/tests/

# dbt auto-generated files
ecommerce_dbt/README.md
ecommerce_dbt/.gitignore

# dbt runtime logs
logs/
